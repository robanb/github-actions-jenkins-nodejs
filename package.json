{
  "name": "github-actions-jenkins-nodejs",
  "version": "1.1.0",
  "description": "A hands-on, open-source Node.js + Express lab demonstrating CI/CD pipelines with both GitHub Actions and Jenkins against the same codebase.",
  "main": "src/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "keywords": [
    "nodejs",
    "express",
    "github-actions",
    "jenkins",
    "ci-cd",
    "devops",
    "pipeline",
    "jest"
  ],
  "author": "Roba Nath Basnet",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/robanb/github-actions-jenkins-nodejs.git"
  },
  "bugs": {
    "url": "https://github.com/robanb/github-actions-jenkins-nodejs/issues"
  },
  "homepage": "https://github.com/robanb/github-actions-jenkins-nodejs#readme",
  "dependencies": {
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "eslint": "^9.13.0",
    "globals": "^15.11.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/server.js"
    ],
    "coverageReporters": [
      "text",
      "text-summary",
      "lcov"
    ],
    "reporters": [
      "default",
      [
        "jest-junit",
        {
          "outputDirectory": "reports/junit",
          "outputName": "junit.xml"
        }
      ]
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 90,
        "lines": 90,
        "statements": 90
      }
    }
  }
}
