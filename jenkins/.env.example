# Copy this file to jenkins/.env and edit the values before the first
# `docker compose up`. docker-compose.yml reads it automatically if it
# sits next to the compose file.
#
# Do NOT commit jenkins/.env — it is gitignored at the repo root.

# Local admin seeded into Jenkins by JCasC (jenkins/casc.yaml).
JENKINS_ADMIN_ID=admin
JENKINS_ADMIN_PASSWORD=change-me
